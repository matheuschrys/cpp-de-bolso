    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "playwright": "^1.61.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.46.0",
    "vite": "^7.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
